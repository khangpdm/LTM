src/main/java/com/example/
│
├── server/
│   ├── Server.java              // Khởi tạo server, lắng nghe socket
│   ├── ClientHandler.java       // Xử lý kết nối từng client
│   └── DataProcessor.java       // Xử lý dữ liệu (gọi API, parse JSON)
│
├── service/
│   ├── CountryService.java      // Lấy thông tin quốc gia (RESTCountries API)
│   ├── CityService.java         // Lấy thông tin thành phố (GeoNames, OpenWeatherMap)
│   ├── HotelService.java        // Lấy thông tin khách sạn (Booking, Agoda, Google Places)
│   └── NewsService.java         // Lấy tin tức/bài báo liên quan (NewsAPI, Wikipedia)
│
├── utils/
│   ├── ApiConnector.java        // Hàm gọi HTTP GET/POST
│   ├── JsonUtils.java           // Parse JSON
│   └── Config.java              // Lưu API key, cấu hình
│
└── client/
    ├── Client.java              // Kết nối tới server
    └── ClientGUI.java           // Giao diện người dùng (Swing/JavaFX)


